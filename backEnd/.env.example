X_RAPIDAPI_HOST=instagram-scraper-api2.p.rapidapi.com
URL=https://instagram-scraper-api2.p.rapidapi.com

# Comma-separated RapidAPI keys — tried left-to-right on rate-limit/failure
X_RAPIDAPI_KEYS=

# every RapidAPI key fails. No trailing slash — /profile/<username> is appended.
SCRAPPER_FALLBACK_URL=

DB=
PORT=8080
# Log level: DEBUG | INFO | NOTICE | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
BUCKET_NAME=instagram-profile-image
ALLOWED_LANGUAGE=english,hinglish,hindi,اردو,spanish,bangla,korean
ALLOWED_ORIGIN=http://localhost:5173,https://instaroasts.com
TOKEN_SECRET=

# Roast job queue (async processing, see backEnd/routes/roastStream.js)
# TTL of the per-job SSE auth token minted at enqueue time
STREAM_TOKEN_TTL=10m
# Per-instance cap on roast jobs actively processed at once
MAX_CONCURRENT_ROAST_JOBS=5

# LLM provider fallback order (comma-separated, tried left-to-right)
# Valid values: groq, gemini, gpt-4o-mini, deepseek
LLM_PROVIDER_ORDER=groq,gemini,gpt-4o-mini,deepseek

# Groq (Llama 4 Scout — vision + text, fastest)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Gemini (vision + text)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (vision + text)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek (text only — skipped for vision requests)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
